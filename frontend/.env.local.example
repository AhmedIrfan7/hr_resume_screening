# Copy this file to .env.local and fill in your n8n Cloud production webhook URLs.
# Get these after importing workflow/hr-resume-screening-submit.json and
# workflow/hr-resume-screening-results.json — see docs/SETUP_GUIDE.md.

NEXT_PUBLIC_N8N_SUBMIT_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/hr-screening/submit
NEXT_PUBLIC_N8N_RESULTS_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/hr-screening/results
